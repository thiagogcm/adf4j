<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>dev.nthings</groupId>
        <artifactId>adf4j-parent</artifactId>
        <version>1.0.1</version>
    </parent>

    <artifactId>adf4j-wasm</artifactId>
    <name>adf4j-wasm</name>
    <description>GraalVM Web Image (WebAssembly) build of adf4j, callable from JavaScript/Node.</description>

    <!-- Built only under the parent `wasm` profile; the generated JS/WASM bundle is not deployed. -->

    <dependencies>
        <dependency>
            <groupId>dev.nthings</groupId>
            <artifactId>adf4j</artifactId>
        </dependency>
        <dependency>
            <groupId>org.graalvm.sdk</groupId>
            <artifactId>webimage-preview</artifactId>
            <version>25.0.3</version>
        </dependency>
        <!-- JSpecify annotations are used by the WASM bridge package metadata. -->
        <dependency>
            <groupId>org.jspecify</groupId>
            <artifactId>jspecify</artifactId>
        </dependency>
        <!-- Tree-mode JSON serialization for bridge responses; avoids hand-rolled escaping. -->
        <dependency>
            <groupId>tools.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
        </dependency>
        <!-- A no-op SLF4J binding keeps the WASM image quiet at runtime. -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-nop</artifactId>
            <scope>runtime</scope>
        </dependency>
    </dependencies>

    <build>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>true</filtering>
            </resource>
        </resources>
        <plugins>
            <!-- Compile the WASM bridge with the Web Image API on the module path. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <release combine.self="override"></release>
                    <source>25</source>
                    <target>25</target>
                    <compilerArgs>
                        <arg>--add-modules</arg>
                        <arg>org.graalvm.webimage.api</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <!-- Build the WebAssembly image for JavaScript/Node consumers. -->
            <plugin>
                <groupId>org.graalvm.buildtools</groupId>
                <artifactId>native-maven-plugin</artifactId>
                <extensions>true</extensions>
                <executions>
                    <execution>
                        <id>build-wasm</id>
                        <goals>
                            <goal>compile-no-fork</goal>
                        </goals>
                        <phase>package</phase>
                    </execution>
                </executions>
                <configuration>
                    <imageName>adf4j-wasm</imageName>
                    <mainClass>dev.nthings.adf4j.wasm.WasmBridge</mainClass>
                    <fallback>false</fallback>
                    <verbose>true</verbose>
                    <buildArgs>
                        <buildArg>--no-fallback</buildArg>
                        <buildArg>--tool:svm-wasm</buildArg>
                        <buildArg>-H:IncludeResources=dev/nthings/adf4j/wasm/adf4j-wasm\\.properties</buildArg>
                    </buildArgs>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
